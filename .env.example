# ================================
# 飞书论文助手 - 环境变量配置
# ================================

# ================================
# 飞书应用配置（必填）
# ================================

# 飞书应用 ID
# 获取方式：飞书开放平台 -> 你的应用 -> 凭证与基础信息 -> App ID
FEISHU_APP_ID=

# 飞书应用 Secret
# 获取方式：飞书开放平台 -> 你的应用 -> 凭证与基础信息 -> App Secret
FEISHU_APP_SECRET=

# ================================
# 群聊配置（必填）
# ================================

# 飞书群聊 ID（用于获取群消息）
# 获取方式：在群设置中点击"群号"或通过 API 获取
# 格式：oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_CHAT_ID=

# ================================
# 多维表格配置（收藏功能必填）
# ================================

# 多维表格 App Token
# 获取方式：打开多维表格 -> URL 中 /base/ 后面的字符串
# 例如 URL: https://xxx.feishu.cn/base/ABC123xyz
# 则 APP_TOKEN = ABC123xyz
FEISHU_BITABLE_APP_TOKEN=

# 收藏表的 Table ID
# 获取方式：打开多维表格的具体表 -> URL 中 ?table= 后面的字符串
# 例如 URL: https://xxx.feishu.cn/base/ABC123xyz?table=tblXXXXXX
# 则 TABLE_ID = tblXXXXXX
FEISHU_COLLECT_TABLE_ID=

# ================================
# AI 配置
# ================================

# DeepSeek API Key（论文筛选、翻译、摘要总结必填）
# 获取方式：https://platform.deepseek.com/
# 用于论文评分筛选、摘要的AI一句话总结和翻译
DEEPSEEK_API_KEY=

# Semantic Scholar API Key（可选，加速作者查询）
# 获取方式：https://www.semanticscholar.org/product/api
# 无此密钥时作者查询较慢（每请求间隔1s）
S2_KEY=

# ================================
# 可选配置
# ================================

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=

# 时区设置
TZ=

# ================================
# 飞书应用权限说明（需要在飞书开放平台开通）
# ================================
# 1. im:message:readonly - 读取群聊消息
# 2. im:message - 获取消息详情  
# 3. im:message:send_as_bot - 发送消息
# 4. bitable:app - 多维表格读写
#
# 开通步骤：
# 1. 访问 https://open.feishu.cn/
# 2. 进入你的应用 -> 权限管理
# 3. 搜索并开通上述权限
# 4. 发布应用新版本使权限生效
